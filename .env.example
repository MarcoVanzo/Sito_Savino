APP_NAME="Savino Del Bene Volley"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
PREVIEW_AUTH_USER=
PREVIEW_AUTH_PASS=

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: MySQL 8 (identico a produzione)
# Avviare con: docker compose up -d
# Per usare SQLite come alternativa rapida: DB_CONNECTION=sqlite (senza host/port/user/pass)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sito_savino
DB_USERNAME=sito_savino
DB_PASSWORD=secret

# Sviluppo: redis (se disponibile). Produzione DigitalOcean: database
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# In produzione impostare a true:
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Sviluppo: redis (se disponibile). Produzione DigitalOcean: database
QUEUE_CONNECTION=redis

# Sviluppo: redis (se disponibile). Produzione DigitalOcean: database
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Client predis (pure PHP, nessuna estensione C richiesta)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=fra1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=https://fra1.digitaloceanspaces.com

VITE_APP_NAME="${APP_NAME}"
COMPREFACE_HOST=http://157.230.98.6:8000
COMPREFACE_KEY=00000000-0000-0000-0000-000000000001
