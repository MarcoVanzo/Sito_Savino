{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowWriteRead",
            "Effect": "Allow",
            "Principal": "*",
            "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:ListBucket",
                "s3:GetBucketLocation"
            ],
            "Resource": [
                "arn:aws:s3:::sito-savino-backups",
                "arn:aws:s3:::sito-savino-backups/*"
            ]
        },
        {
            "Sid": "DenyDeleteObjects",
            "Effect": "Deny",
            "Principal": "*",
            "Action": [
                "s3:DeleteObject",
                "s3:DeleteObjectVersion",
                "s3:DeleteBucket"
            ],
            "Resource": [
                "arn:aws:s3:::sito-savino-backups",
                "arn:aws:s3:::sito-savino-backups/*"
            ]
        }
    ]
}
